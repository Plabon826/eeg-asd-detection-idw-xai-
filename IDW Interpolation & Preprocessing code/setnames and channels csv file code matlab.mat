% Add EEGLAB to the MATLAB path (if not done already)
addpath(genpath('path_to_eeglab'));  % Replace with the actual path to EEGLAB

% Initialize EEGLAB
eeglab;

% Define the directory where the .set files are located
folderPath = '/Users/hello/Desktop/16840351/';  % Update this to your correct path

% Get all .set files in the folder
files = dir(fullfile(folderPath, '*.set'));
numFiles = length(files);

% Initialize arrays to store the metadata for the CSV
filenames = cell(numFiles, 1);
setnames = cell(numFiles, 1);
nbchan_values = zeros(numFiles, 1);
channel_descriptions = cell(numFiles, 1);  % Array to store channel descriptions

% Loop through all the files and load each .set file
for i = 1:numFiles
    % Load the EEG dataset
    EEG = pop_loadset('filename', files(i).name, 'filepath', folderPath);
    
    % Store the relevant metadata
    filenames{i} = files(i).name;
    setnames{i} = EEG.setname;
    nbchan_values(i) = EEG.nbchan;
    
    % Collect channel descriptions (names, positions, etc.)
    % Using the `icachansind` field to map indices to channel names
    channel_info = {EEG.chanlocs.labels};  % Channel names (labels)
    
    % Get the channel names corresponding to the indices in `icachansind`
    selected_channels = {EEG.chanlocs(EEG.icachansind).labels};  % Extract the channel names for selected indices
    channel_descriptions{i} = strjoin(selected_channels, ', ');  % Join all channels into a single string separated by commas
end

% Create a table to display the collected information
metadataTable = table(filenames, setnames, nbchan_values, channel_descriptions);

% Define the output CSV file path
outputFile = '/Users/hello/Desktop/EEG_Metadata.csv';  % Update with the desired output path

% Write the table to a CSV file
writetable(metadataTable, outputFile);

% Display success message
disp(['Metadata has been successfully written to: ', outputFile]);
